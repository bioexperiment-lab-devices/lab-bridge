{
    email __ACME_EMAIL__
    default_sni __VPS_HOST__
}

https://__VPS_HOST__ {
    tls {
        issuer acme {
            profile shortlived
        }
    }

    # Static assets (CSS, JS) for siteapp templates. Without this, the
    # browser request for /_static/site.css falls through to the jupyter
    # catchall and 404s, leaving every siteapp page unstyled.
    handle /_static/* {
        reverse_proxy siteapp:8000
    }

    # Public docs. Use `handle` (not `handle_path`) so the upstream sees the
    # full `/docs/...` path: siteapp's FastAPI routes are declared on
    # `/docs/{path:path}`, so prefix-stripping would 404 every request.
    handle /docs* {
        reverse_proxy siteapp:8000
    }

    # Public agent download page + binary. Same reasoning — siteapp routes
    # are declared on `/download/agent` and `/download/agent/windows/agent.exe`.
    handle /download* {
        reverse_proxy siteapp:8000
    }

    # Admin panel — basic_auth scoped here ONLY. Mobile-WS issue does not
    # apply: this surface is plain HTTP file uploads, no kernels.
    handle /admin* {
        basic_auth {
            admin __ADMIN_BCRYPT_HASH__
        }
        reverse_proxy siteapp:8000
    }

    # CI upload endpoint — bearer-token auth in the app, not Caddy.
    handle /api/agent/upload {
        reverse_proxy siteapp:8000
    }

    # Existing routes (unchanged).
    handle /grafana/* {
        reverse_proxy grafana:3000
    }
    reverse_proxy jupyter:8888
}
